# --- Compression settings (all optional, defaults shown) ---
JPEG_QUALITY=78
PNG_QUALITY_MIN=55
PNG_QUALITY_MAX=78
WEBP_QUALITY=78
MAX_WIDTH=2400
SKIP_UNDER_KB=50
WORKERS=4

# --- R2 Upload settings ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_KEY_PREFIX=
